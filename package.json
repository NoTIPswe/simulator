{
  "name": "notip-simulator-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:cov": "ng test --code-coverage",
    "format": "prettier --write \"src/**/*.{ts,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\"",
    "lint": "eslint \"src/**/*.{ts,html}\" --fix",
    "lint:check": "eslint \"src/**/*.{ts,html}\" --max-warnings=0",
    "lint:report": "eslint \"src/**/*.{ts,html}\" --format json --output-file eslint-report.json",
    "typecheck": "npx tsc --noEmit --project tsconfig.json",
    "import:openapi": "bash scripts/import-openapi.sh",
    "import:async": "bash scripts/import-asyncapi.sh"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-builders/jest": "^21.0.3",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^30.0.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gitleaks": "^1.0.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-sonar": "^0.2.16",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.0.8"
  }
}
